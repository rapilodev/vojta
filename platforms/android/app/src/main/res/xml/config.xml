<?xml version='1.0' encoding='utf-8'?>
<widget id="org.vojta-watchclock" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <feature name="Whitelist">
        <param name="android-package" value="org.apache.cordova.whitelist.WhitelistPlugin" />
        <param name="onload" value="true" />
    </feature>
    <name>Vojta</name>
    <description>
        A watchclock for multiple Vojta rounds
    </description>
    <author email="rapilodev+vojta@gmail.com" href="http://cordova.io">
        Milan Chrobok
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="market:*" />
    <preference name="loglevel" value="DEBUG" />
</widget>
